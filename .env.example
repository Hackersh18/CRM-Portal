# Copy to ".env" and fill in values.
SECRET_KEY=your-secret-key-min-50-chars-random

# Django
DJANGO_DEBUG=True
# Hostnames only — no https://, no trailing slash (e.g. not example.com/)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Production (HTTPS): comma-separated full origins, no trailing slash
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# On Vercel, ALLOWED_HOSTS / CSRF are extended from VERCEL_URL and .vercel.app when VERCEL=1.

# Supabase Postgres — Dashboard → Project Settings → Database
# For Vercel/serverless: use Transaction pooler (port 6543) — higher connection limit than Session (5432).
# Session pooler exhausts quickly → "MaxClientsInSessionMode". Example transaction URI:
# DATABASE_URL=postgresql://postgres.[REF]:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# If you use Session pool (5432), CONN_MAX_AGE defaults to 0 for *.pooler.supabase.com to avoid pool exhaustion.
# Direct db.*.supabase.co: avoid on PaaS; prefer pooler. DATABASE_PREFER_IPV4=true if IPv6 errors locally.
# On Vercel/Railway, settings auto-prefer IPv4 when connecting to the DB host.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Local dev only: force SQLite instead of Postgres (when DJANGO_DEBUG=True)
# USE_SQLITE_LOCAL=true
