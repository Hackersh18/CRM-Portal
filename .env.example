# Copy to ".env" and fill in values.
SECRET_KEY=your-secret-key-min-50-chars-random

# Django
DJANGO_DEBUG=True
# Hostnames only — no https://, no trailing slash (e.g. not example.com/)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Production (HTTPS): comma-separated full origins, no trailing slash
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# On Vercel, ALLOWED_HOSTS / CSRF are extended from VERCEL_URL and .vercel.app when VERCEL=1.

# Supabase Postgres — Dashboard → Project Settings → Database
# Prefer Session pooler host (aws-0-*.pooler.supabase.com), not db.*.supabase.co, for serverless/PaaS.
# If you see "Cannot assign requested address" (IPv6), use the pooler URI or set DATABASE_PREFER_IPV4=true.
# On Vercel/Railway, settings auto-prefer IPv4 when connecting to the DB host.
# Transaction pooler (port 6543): set SUPABASE_TRANSACTION_POOLER=True (CONN_MAX_AGE=0).
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Local dev only: force SQLite instead of Postgres (when DJANGO_DEBUG=True)
# USE_SQLITE_LOCAL=true
